generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id       Int      @id @default(autoincrement())
  key      String   @unique
  valueEn  String?  @db.Text @map("value_en")
  valueId  String?  @db.Text @map("value_id")
  group    String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model Slide {
  id              Int      @id @default(autoincrement())
  type            String   @default("custom")
  titleEn         String   @map("title_en")
  titleId         String?  @map("title_id")
  descriptionEn   String?  @db.Text @map("description_en")
  descriptionId   String?  @db.Text @map("description_id")
  overlineEn      String?  @map("overline_en")
  overlineId      String?  @map("overline_id")
  buttonTextEn    String?  @map("button_text_en")
  buttonTextId    String?  @map("button_text_id")
  buttonLink      String?  @map("button_link")
  image           String?
  backgroundImage String?  @map("background_image")
  backgroundColor String   @default("#0a1628") @map("background_color")
  sortOrder       Int      @default(0) @map("sort_order")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("slides")
}

model Personnel {
  id        Int      @id @default(autoincrement())
  name      String
  roleEn    String   @map("role_en")
  roleId    String?  @map("role_id")
  bioEn     String?  @db.Text @map("bio_en")
  bioId     String?  @db.Text @map("bio_id")
  photo     String?
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("personnel")
}

model Program {
  id            Int      @id @default(autoincrement())
  titleEn       String   @map("title_en")
  titleId       String?  @map("title_id")
  descriptionEn String?  @db.Text @map("description_en")
  descriptionId String?  @db.Text @map("description_id")
  emoji         String   @default("📖")
  image         String?
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("programs")
}

model Activity {
  id            Int      @id @default(autoincrement())
  type          String
  time          String
  activityEn    String   @map("activity_en")
  activityId    String?  @map("activity_id")
  descriptionEn String?  @db.Text @map("description_en")
  descriptionId String?  @db.Text @map("description_id")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("activities")
}

model Mission {
  id            Int      @id @default(autoincrement())
  titleEn       String   @map("title_en")
  titleId       String?  @map("title_id")
  dateLabelEn   String?  @map("date_label_en")
  dateLabelId   String?  @map("date_label_id")
  descriptionEn String?  @db.Text @map("description_en")
  descriptionId String?  @db.Text @map("description_id")
  image         String?
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("missions")
}

model News {
  id          Int       @id @default(autoincrement())
  titleEn     String    @map("title_en")
  titleId     String?   @map("title_id")
  tagEn       String    @default("News") @map("tag_en")
  tagId       String    @default("Berita") @map("tag_id")
  contentEn   String?   @db.Text @map("content_en")
  contentId   String?   @db.Text @map("content_id")
  image       String?
  publishedAt DateTime? @map("published_at")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("news")
}
model ActivityGallery {
  id           Int             @id @default(autoincrement())
  activityDate DateTime
  titleEn      String
  titleId      String?
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  photos       ActivityPhoto[]
}

model ActivityPhoto {
  id        Int             @id @default(autoincrement())
  image     String
  galleryId Int
  gallery   ActivityGallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)
}
model GuestSpeaker {
  id          Int      @id @default(autoincrement())
  name        String
  origin      String?  // Untuk menyimpan asal gereja, pelayanan, atau profesi
  image       String   // Untuk menyimpan foto pembicara
  dateServed  DateTime // Tanggal saat melayani di M-YES
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("guest_speakers")
}
model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String   @db.Text
  isRead    Boolean  @default(false) // Penanda apakah pesan sudah dibaca admin
  createdAt DateTime @default(now())

  @@map("contact_messages")
}